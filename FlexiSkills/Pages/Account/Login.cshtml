@page
@model FlexiSkills.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-page">
    <div class="form">
              
        <div class="logo"></div>
        <form method="post">
            <input asp-for="Model.MatricNo" type="text" placeholder="Matric No."/>
			<span asp-validation-for="Model.MatricNo"></span>
            <input asp-for="Model.Password" type="password" placeholder="Password"/>
			<span asp-validation-for="Model.Password"></span>
            <button>login</button>
        </form>
    </div>
</div>